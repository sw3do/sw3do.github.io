---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="404 — Mert Çelik" description="Page not found.">
  <Nav />
  <main id="main" class="wrap">
    <div class="container box">
      <div class="term">
        <div class="bar"><i></i><i></i><i></i></div>
        <div class="body">
          <p><span class="p">~/mert $</span> open requested-page</p>
          <p class="err">error: 404 — no such file or directory</p>
          <p><span class="p">~/mert $</span> <span class="caret"></span></p>
        </div>
      </div>
      <h1>Page not found</h1>
      <p class="muted">That route doesn't exist. Let's get you back.</p>
      <a class="btn" href="/">Go home</a>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .wrap { padding: 120px 0 60px; }
  .box { max-width: 560px; text-align: center; }
  .term {
    text-align: left;
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow);
    margin-bottom: 36px;
  }
  .bar { display: flex; gap: 7px; padding: 11px 14px; border-bottom: 1px solid var(--border); }
  .bar i { width: 11px; height: 11px; border-radius: 50%; background: var(--border-strong); }
  .bar i:nth-child(1) { background: #ff5f56; }
  .bar i:nth-child(2) { background: #ffbd2e; }
  .bar i:nth-child(3) { background: #27c93f; }
  .body { padding: 18px; font-family: var(--font-mono); font-size: 13.5px; line-height: 2; }
  .body .p { color: var(--accent); }
  .body .err { color: #ff7b72; }
  .body a { color: var(--text); text-decoration: underline; }
  .caret { display: inline-block; width: 8px; height: 15px; background: var(--accent); vertical-align: text-bottom; }
  h1 { font-size: 2rem; }
  .muted { margin: 10px 0 24px; }
  .btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 14px;
    background: var(--accent);
    color: var(--on-accent);
    border-radius: 9px;
    padding: 11px 20px;
  }
  .btn:hover { background: var(--accent-strong); text-decoration: none; }
</style>
