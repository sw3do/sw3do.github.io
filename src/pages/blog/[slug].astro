---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const entries = (await getCollection('blog')).filter((e) => !e.data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, date, tags } = entry.data;
const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  author: { '@type': 'Person', name: 'Mert Çelik' },
  url: new URL(`/blog/${entry.id}`, Astro.site).href,
};
---
<ArticleLayout
  title={title}
  description={description}
  eyebrow="blog"
  backHref="/blog"
  backLabel="All posts"
  jsonLd={jsonLd}
>
  <Fragment slot="meta">
    <div class="postmeta">
      <time datetime={date.toISOString()}>{fmt}</time>
      {tags.length > 0 && <span>· {tags.join(' · ')}</span>}
    </div>
  </Fragment>
  <Content />
</ArticleLayout>

<style>
  .postmeta {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--muted);
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .postmeta time { color: var(--accent); }
</style>
