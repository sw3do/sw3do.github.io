---
import { Icon } from 'astro-icon/components';
import { profile } from '../data/profile';
import { stackLines } from '../data/skills';
const pad = (k: string) => k.padEnd(10, ' ');
---
<section class="hero" id="top">
  <div class="bg" aria-hidden="true"></div>
  <div class="container hero-grid">
    <div class="copy">
      <p class="eyebrow line">// Software Engineer · {profile.location.split(',')[0]}</p>
      <h1 class="headline">
        Building backends,<br />systems &amp; <span class="accent">full-stack apps.</span>
      </h1>
      <p class="bio">{profile.bio}</p>
      <div class="cta">
        <a class="btn primary" href="#projects">View projects <Icon name="lucide:arrow-right" /></a>
        <a class="btn outline" href="/Mert-Celik-CV.pdf" target="_blank" rel="noopener">
          <Icon name="lucide:download" /> Download CV
        </a>
        <a class="btn ghost" href={profile.github} target="_blank" rel="noopener">
          <Icon name="simple-icons:github" /> GitHub
        </a>
      </div>
    </div>

    <div class="term-wrap">
      <div class="term" role="img" aria-label="Terminal showing Mert's technology stack">
        <div class="term-bar"><i></i><i></i><i></i><span class="term-title">mert@berlin: ~</span></div>
        <div class="term-body">
          <div class="prompt"><span class="p">~/mert $</span> cat stack.txt</div>
          {stackLines.map((l) => (
            <div class="row"><span class="k">{pad(l.key)}</span><span class="v">{l.value}</span></div>
          ))}
          <div class="prompt"><span class="p">~/mert $</span> <span class="caret"></span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 120px 0 96px;
    overflow: hidden;
  }
  .bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(680px 320px at 18% -8%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 70%),
      radial-gradient(520px 300px at 100% 0%, color-mix(in srgb, var(--accent) 9%, transparent), transparent 70%);
    pointer-events: none;
  }
  .bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(620px 420px at 30% 20%, #000 0%, transparent 75%);
    -webkit-mask-image: radial-gradient(620px 420px at 30% 20%, #000 0%, transparent 75%);
    opacity: 0.5;
  }
  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 48px;
    align-items: center;
  }
  .eyebrow.line { margin: 0 0 14px; }
  .headline {
    font-size: clamp(2rem, 5.2vw, 3.4rem);
    font-weight: 700;
    letter-spacing: -1px;
  }
  .headline .accent { color: var(--accent); }
  .bio {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-top: 18px;
    max-width: 30rem;
  }
  .cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    border-radius: 9px;
    padding: 11px 18px;
    transition: transform 0.15s ease, background 0.18s ease, border-color 0.18s ease, color 0.18s ease;
  }
  .btn :global(svg) { width: 16px; height: 16px; }
  .btn:hover { text-decoration: none; transform: translateY(-2px); }
  .btn.primary { background: var(--accent); color: var(--on-accent); }
  .btn.primary:hover { background: var(--accent-strong); }
  .btn.outline { border: 1px solid var(--border-strong); color: var(--text); }
  .btn.outline:hover { border-color: var(--accent); color: var(--accent); }
  .btn.ghost { color: var(--muted); }
  .btn.ghost:hover { color: var(--accent); }

  .term {
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow);
    font-family: var(--font-mono);
  }
  .term-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 11px 14px;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface-2) 60%, var(--surface));
  }
  .term-bar i { width: 11px; height: 11px; border-radius: 50%; background: var(--border-strong); }
  .term-bar i:nth-child(1) { background: #ff5f56; }
  .term-bar i:nth-child(2) { background: #ffbd2e; }
  .term-bar i:nth-child(3) { background: #27c93f; }
  .term-title { margin-left: 8px; font-size: 12px; color: var(--muted); }
  .term-body { padding: 18px 18px 20px; font-size: 13.5px; line-height: 1.95; }
  .prompt .p { color: var(--accent); }
  .row .k { color: var(--muted); white-space: pre; }
  .row .v { color: var(--text); }
  .caret {
    display: inline-block;
    width: 9px;
    height: 16px;
    vertical-align: text-bottom;
    background: var(--accent);
    animation: blink 1.1s steps(1) infinite;
  }

  @media (prefers-reduced-motion: no-preference) {
    .copy > *, .term-wrap { opacity: 0; transform: translateY(14px); animation: rise 0.6s ease forwards; }
    .copy > *:nth-child(1) { animation-delay: 0.05s; }
    .copy > *:nth-child(2) { animation-delay: 0.13s; }
    .copy > *:nth-child(3) { animation-delay: 0.21s; }
    .copy > *:nth-child(4) { animation-delay: 0.29s; }
    .term-wrap { animation-delay: 0.28s; }
  }
  @keyframes blink { 50% { opacity: 0; } }
  @keyframes rise { to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; gap: 36px; }
    .hero { padding: 96px 0 72px; }
  }
</style>
