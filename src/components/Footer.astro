---
import { Icon } from 'astro-icon/components';
import { profile } from '../data/profile';
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container inner">
    <span class="left">© {year} {profile.name}</span>
    <span class="mid">Built with Astro · deployed on GitHub Pages</span>
    <a class="top" href="#top">back to top <Icon name="lucide:arrow-up" /></a>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 28px 0;
    margin-top: 40px;
  }
  .inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--muted);
  }
  .top { display: inline-flex; align-items: center; gap: 6px; color: var(--muted); }
  .top :global(svg) { width: 14px; height: 14px; }
  .top:hover { color: var(--accent); text-decoration: none; }

  @media (max-width: 560px) {
    .mid { order: 3; width: 100%; }
  }
</style>
