---
import { Icon } from 'astro-icon/components';
import { skillGroups } from '../data/skills';
---
<section class="section skills" id="skills">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">// skills</p>
      <h2>Tools I build with</h2>
    </div>
    <div class="rows">
      {skillGroups.map((g) => (
        <div class="row">
          <div class="label">{g.label}</div>
          <ul class="chips">
            {g.items.map((it) => (
              <li class="chip">
                <Icon name={it.icon} class="ic" />
                <span>{it.name}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .rows { display: flex; flex-direction: column; }
  .row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 28px;
    padding: 22px 0;
    border-top: 1px solid var(--border);
    align-items: baseline;
  }
  .row:last-child { border-bottom: 1px solid var(--border); }
  .label {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .chips {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text);
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    padding: 7px 12px;
    background: var(--surface);
    transition: border-color 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }
  .chip .ic { width: 15px; height: 15px; color: var(--muted); transition: color 0.18s ease; }
  .chip:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }
  .chip:hover .ic { color: var(--accent); }

  @media (max-width: 640px) {
    .row { grid-template-columns: 1fr; gap: 12px; }
  }
</style>
